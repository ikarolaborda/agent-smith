{
  "schema_version": 1,
  "id": "native-clang-libfuzzer-v2",
  "name": "Native Clang libFuzzer",
  "version": "2.0.0",
  "image_digest": "${IMAGE_DIGEST}",
  "engine": "libfuzzer",
  "sanitizers": ["address", "undefined"],
  "architectures": ["amd64", "arm64"],
  "harnesses": [
    {
      "name": "micro_oob",
      "binary": "/build/fuzz_target",
      "seed_corpus": "/corpus",
      "dictionary": "/source/apparatus/native-clang/dictionaries/micro_oob.dict",
      "options": ["-timeout=5", "-max_len=4096"],
      "max_input_len": 4096
    },
    {
      "name": "micro_oob_clean",
      "binary": "/build/fuzz_target",
      "seed_corpus": "/corpus",
      "dictionary": "/source/apparatus/native-clang/dictionaries/micro_oob_clean.dict",
      "options": ["-timeout=5", "-max_len=4096"],
      "max_input_len": 4096
    }
  ],
  "operations": [
    "inspect", "build", "list_harnesses", "smoke_test", "seed", "fuzz",
    "reproduce", "minimize", "merge_corpus", "coverage", "symbolize",
    "compare_revision", "regression_test"
  ],
  "environment": {
    "ASAN_OPTIONS": "abort_on_error=1:symbolize=1",
    "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
  },
  "limits": {
    "max_wall_seconds": 3600,
    "max_memory_bytes": 2147483648,
    "max_cpu_seconds": 3600,
    "max_disk_bytes": 1073741824,
    "max_pids": 64,
    "max_concurrent": 1
  }
}
