# Build artifacts
bin/
*.test
*.prof
*.log
coverage.out
coverage.html

# TypeScript incremental build cache — regenerated by every `tsc` run.
*.tsbuildinfo

# Top-level dist (does NOT match web/dist — see the rule below)
/dist/

# web/dist is referenced by `//go:embed all:dist` in web/embed.go, so the
# directory must exist at compile time. We keep a placeholder index.html and
# ignore every generated asset; `make build` regenerates the real bundle.
web/dist/*
!web/dist/index.html
!web/dist/.gitkeep

# Node dependencies
node_modules/
web/node_modules/

# Local dotenv files
.env
.env.*
!.env.example

# Editor / OS noise
.idea/
.vscode/
.DS_Store
*.swp
*.swo
Thumbs.db

# Local agent / tooling state (must NOT be committed)
.agent/
.agent-smith/
apparatus/native-clang/manifest.json
.serena/
.claude/

# RAG cached embeddings (re-ingested on first run)
data/rag/collections/*.json
data/rag/collections/*.sqlite
data/rag/collections/*.sqlite-shm
data/rag/collections/*.sqlite-wal
!data/rag/collections/.gitkeep

# Autonomous GGUF downloads can be tens of gigabytes. The normal default is
# outside the repository; this covers the no-home fallback and local overrides.
data/models/
*.gguf
*.gguf.part
