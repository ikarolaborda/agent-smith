# Copy to .env and fill in. The agent loads .env from the project root AND
# from the directory of the YAML config (e.g. configs/.env when --config
# points at configs/config.example.yaml). Real environment variables take
# precedence over both.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama runs locally and needs no key by default.
# OLLAMA_BASE_URL=http://localhost:11434

# Context7 documentation augmentation: when set, every model transparently
# gets current library docs injected into its context. Leave unset to disable.
# CONTEXT7_API_KEY=ctx7-...
# CONTEXT7_BASE_URL=https://context7.com/api/v2
