# Copy to .env and fill in. The agent loads this file from the directory
# of the YAML config (e.g. configs/.env when --config points at
# configs/config.example.yaml). Real environment variables take precedence.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama runs locally and needs no key by default.
# OLLAMA_BASE_URL=http://localhost:11434
